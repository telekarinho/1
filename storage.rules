rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // TV Indoor — Mídia para Digital Signage
    // ============================================
    // Leitura pública: TV Android, celular, browser kiosk — nenhum tem sessão auth.
    // A URL já contém um token único gerado no upload (impossível adivinhar).
    // Escrita: pública com limite de tamanho 500MB (o painel controla quem sobe).
    // Delete: somente autenticado (protege contra remoção externa).
    match /tv-media/{franchiseId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 500 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // ============================================
    // Áudio — Radio Indoor
    // ============================================
    match /radio-audio/{franchiseId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ============================================
    // Imagens de Produtos / Cardápio
    // ============================================
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================
    // Assets do sistema (logos, banners, etc.)
    // ============================================
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
                      request.auth.token.role == 'super_admin';
    }

    // ============================================
    // Bloqueia tudo que não foi definido explicitamente
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
