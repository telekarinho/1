{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/tv.apk",
      "destination": "https://github.com/telekarinho/1/releases/download/tv-apk-latest/tv.apk",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/cron-ig-stories",
      "schedule": "0 23 * * *"
    }
  ]
}
