{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "storage.rules",
      "vercel.json",
      "package.json",
      "package-lock.json",
      "setup-owner.js",
      "tmp-*.js",
      ".gitignore",
      ".vercel/**",
      "api/**",
      "**/node_modules/**",
      "functions/**",
      ".github/**",
      ".claude/**",
      "*.md"
    ],
    "headers": [
      {
        "source": "/tv.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma",        "value": "no-cache" },
          { "key": "Expires",       "value": "0" }
        ]
      },
      {
        "source": "/tv@(1|2|3).html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma",        "value": "no-cache" },
          { "key": "Expires",       "value": "0" }
        ]
      },
      {
        "source": "/tv-app.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma",        "value": "no-cache" },
          { "key": "Expires",       "value": "0" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/clube",
        "destination": "/clube/"
      },
      {
        "source": "/clube/app",
        "destination": "/clube.html"
      },
      {
        "source": "/clube/regulamento",
        "destination": "/regulamento-milkyclube.html"
      },
      {
        "source": "/f/**",
        "destination": "/f/index.html"
      }
    ]
  }
}
