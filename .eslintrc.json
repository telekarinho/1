{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "globals": {
    "firebase": "readonly",
    "DataStore": "readonly",
    "Auth": "readonly",
    "CatalogV2": "readonly",
    "MilkyClube": "readonly",
    "CloudFunctions": "readonly",
    "CARDAPIO_CONFIG": "readonly",
    "MILKYPOT_STORES": "readonly",
    "MonteSeuFlow": "readonly",
    "FRANCHISE": "readonly"
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": "off",
    "no-redeclare": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    ".tmp_*",
    "functions/node_modules/",
    "scripts/",
    "*.min.js"
  ]
}
