<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MilkyPot TV"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Qual TV é esta?"
        android:textColor="#BBBBBB"
        android:textSize="20sp"
        android:paddingBottom="32dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnTv1"
            style="@style/MpButton"
            android:text="TV 1" />
        <Button
            android:id="@+id/btnTv2"
            style="@style/MpButton"
            android:text="TV 2" />
        <Button
            android:id="@+id/btnTv3"
            style="@style/MpButton"
            android:text="TV 3" />
    </LinearLayout>

    <!-- TV especial do Desafio (lado do caixa) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— ou —"
            android:textColor="#888888"
            android:textSize="14sp"
            android:paddingBottom="8dp" />
        <Button
            android:id="@+id/btnChallenge"
            style="@style/MpButton"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:text="🎯 TV do Desafio"
            android:textSize="20sp" />
        <TextView
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:text="TV dedicada ao Desafio 10s + 300g (ao lado do caixa)"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnBelinha"
            style="@style/MpButton"
            android:layout_width="380dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:background="#FF4F8A"
            android:text="🐑 Belinha AI (copiloto)"
            android:textSize="18sp" />
        <TextView
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:text="Abre o copiloto executivo MilkyPot em modo tablet"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="24dp">

        <EditText
            android:id="@+id/customCode"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:hint="outro código (ex: mq1)"
            android:textColorHint="#999"
            android:textColor="@android:color/white"
            android:background="#1F2937"
            android:padding="12dp"
            android:inputType="textNoSuggestions"
            android:autofillHints="off"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnCustom"
            style="@style/MpButton"
            android:text="Usar" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A escolha é lembrada pras próximas vezes"
        android:textColor="#666"
        android:textSize="13sp"
        android:paddingTop="32dp" />
</LinearLayout>
