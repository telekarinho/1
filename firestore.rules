rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper Functions
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth != null ? request.auth.token.role : null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isFranchisee() {
      return isAuthenticated() && getUserRole() == 'franchisee';
    }

    function belongsToFranchise(franchiseId) {
      return isAuthenticated() && request.auth.token.franchiseId == franchiseId;
    }

    function isAdminOrFranchiseOwner(franchiseId) {
      return isSuperAdmin() || belongsToFranchise(franchiseId);
    }

    // ============================================
    // DataStore Collection (legado - fase de migracao)
    // ============================================
    match /datastore/{document} {
      // Franchises list e publica (necessario para listagem de lojas)
      // iFood docs sao escritos pela extensao Chrome (sem auth - limitacao tecnica)
      // tv_* docs (media library, playlist, config) sao lidos por TVs Android,
      // celulares e browsers kiosk que nao tem sessao auth
      // tv_remote_* docs (comandos da TV Remote) tambem sao publicos p/ controlar TVs
      // orders_* / caixa_* / pdv_tabs_* / finances_*: leitura publica pra sync entre
      // PCs do PDV funcionar mesmo se Firebase Auth perdeu o token (IDB limpo, browser
      // separado). Writes continuam restritos a auth — operadores PRECISAM logar pra
      // criar/alterar pedidos. Inauguracao prioriza disponibilidade; tightening pos.
      allow read: if document == 'franchises'
                    || document.matches('ifood_.*')
                    || document.matches('tv_.*')
                    || document.matches('tvremote_.*')
                    || document.matches('radio_.*')
                    || document.matches('orders_.*')
                    || document.matches('caixa_.*')
                    || document.matches('pdv_tabs_.*')
                    || document.matches('finances_.*')
                    || isAuthenticated();
      // Franchises: somente super_admin pode escrever
      // iFood: extensao escreve sem auth (aceito temporariamente)
      // tv_remote_*: comandos da remote podem ser escritos sem auth (app controla)
      // Outros: usuarios autenticados (franqueados) escrevem seus proprios dados
      allow write: if document.matches('ifood_.*') ||
                      document.matches('tvremote_.*') ||
                      (isSuperAdmin() && document == 'franchises') ||
                      (isAuthenticated() && document != 'franchises');
    }

    // ============================================
    // Users (perfis de usuario)
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isSuperAdmin()
      );
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && resource.data.role != 'super_admin';
    }

    // ============================================
    // Franchises (dados de franquias)
    // ============================================
    match /franchises/{franchiseId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();

      match /orders/{orderId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow create: if isAdminOrFranchiseOwner(franchiseId);
        allow update: if isAdminOrFranchiseOwner(franchiseId);
        allow delete: if isSuperAdmin();
      }

      match /finances/{financeId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow write: if isAdminOrFranchiseOwner(franchiseId);
      }

      match /inventory/{itemId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow write: if isAdminOrFranchiseOwner(franchiseId);
      }

      match /staff/{staffId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow write: if isAdminOrFranchiseOwner(franchiseId);
      }
    }

    // ============================================
    // Products (cardapio centralizado - publico)
    // ============================================
    match /products/{productId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ============================================
    // Payments (pagamentos de franquia)
    // ============================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // Settings / Config (configuracoes do sistema)
    // ============================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Config publica (necessario para o jogo Desafio ler premios/config)
    match /config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ============================================
    // Audit Log (somente admin le, imutavel)
    // ============================================
    match /audit_log/{logId} {
      allow read: if isSuperAdmin();
      // Apenas permite criar se o userId do log corresponde ao usuario autenticado
      // Impede injecao de logs falsos
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Imutavel
    }

    // ============================================
    // Delivery Tracking (posicao GPS em tempo real)
    // ============================================
    match /delivery_tracking/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isSuperAdmin(); // Apenas admin pode deletar rastreamento
    }

    // ============================================
    // DESAFIO 10 MILKYPOT — Collections do jogo
    // ============================================

    // Vouchers gerados pelo PDV / fiscal / delivery
    match /desafio_vouchers/{voucherId} {
      // Leitura publica: necessario para validar voucher no jogo
      allow read: if true;
      // Criacao: apenas sistemas autenticados (PDV, fiscal)
      allow create: if isAuthenticated();
      // Update: jogo marca como usado (idealmente via Cloud Function)
      allow update: if true;
      allow delete: if isSuperAdmin();
    }

    // Resultados das partidas
    match /desafio_10000/{gameId} {
      allow read: if true;  // Publico para ranking
      allow create: if true; // Qualquer jogador salva resultado
      allow update: if true; // Atualiza URL do video de reacao
      allow delete: if isSuperAdmin();
    }

    // Streaks dos jogadores (por telefone)
    match /desafio_streaks/{playerId} {
      allow read: if true;
      allow write: if true;
    }

    // Cartelas de carimbo (stamp cards)
    match /desafio_stamps/{playerId} {
      allow read: if true;
      allow write: if true;
    }

    // Opt-in de notificacoes WhatsApp
    match /desafio_notifications/{playerId} {
      allow read: if isSuperAdmin();
      allow write: if true;
    }

    // ============================================
    // RASPINHA DA SORTE - Cada pedido gera 1 raspinha
    // ============================================
    match /scratches/{scratchCode} {
      // Leitura publica: cliente precisa acessar sua raspinha pelo codigo
      // Codigo tem 218 trilhoes combinacoes - seguro por obscuridade
      allow read: if true;
      // Criacao: PDV/sistema autenticado gera raspinha
      allow create: if true;
      // Update: cliente raspa (muda status) e funcionario resgata
      allow update: if true;
      // Delete: apenas super_admin
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // MILKYCLUBE — Programa de fidelidade v1
    // Coins/Tiers/Transactions/Referrals/FCM
    // ============================================

    // Config global do MilkyClube (tiers, bonus, feature flags)
    // Leitura publica para o PWA do clube montar a UI
    match /club_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Membros do clube (1 doc por UID Firebase Auth)
    // Cliente pode ler seu proprio doc e atualizar dados cadastrais
    // mas NUNCA coins/tier/totals (somente Cloud Functions)
    match /club_members/{memberId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == memberId || isSuperAdmin() || isFranchisee()
      );
      allow create: if isAuthenticated() && request.auth.uid == memberId;
      allow update: if isAuthenticated()
        && request.auth.uid == memberId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'coins', 'totalEarned', 'totalRedeemed',
          'tier', 'tierProgress', 'ordersCount', 'totalSpent',
          'birthdayClaimedYear', 'firstOrderBonusClaimed',
          'referralCount', 'referralCode', 'referredBy'
        ]);
      allow delete: if isSuperAdmin();
    }

    // Transacoes de MilkyCoins - imutaveis, so Cloud Function escreve
    match /milkycoins_transactions/{txId} {
      allow read: if isAuthenticated() && (
        resource.data.memberId == request.auth.uid || isSuperAdmin() || isFranchisee()
      );
      allow write: if false; // Somente Cloud Functions via admin SDK
    }

    // Codigos de indicacao (referral) - leitura publica para validar codigo
    match /club_referrals/{code} {
      allow read: if true;
      allow write: if false; // Somente Cloud Functions
    }

    // Tokens FCM (push) - somente Cloud Functions gravam
    match /fcm_tokens/{tokenHash} {
      allow read: if isSuperAdmin();
      allow write: if false; // Somente Cloud Functions
    }

    // Fila de envios WhatsApp - franqueado le sua fila, CF escreve
    match /whatsapp_queue/{queueId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow update: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow create, delete: if false; // Somente Cloud Functions criam
    }

    // Agenda de postagens de marketing (plano viral MilkyClube IG/TikTok)
    match /marketing_agenda/{postId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // Bloqueia tudo que nao foi definido explicitamente
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
