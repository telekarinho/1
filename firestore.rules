rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper Functions
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth != null ? request.auth.token.role : null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'super_admin';
    }

    function isFranchisee() {
      return isAuthenticated() && getUserRole() == 'franchisee';
    }

    function belongsToFranchise(franchiseId) {
      return isAuthenticated() && request.auth.token.franchiseId == franchiseId;
    }

    function isAdminOrFranchiseOwner(franchiseId) {
      return isSuperAdmin() || belongsToFranchise(franchiseId);
    }

    // ============================================
    // Test Tokens (validacao via login.html sem auth previa)
    // ============================================
    // Tokens sao UUIDs longos (32 bytes) gerados por Cloud Function
    // generateTestToken. Login.html precisa LER pra validar o token
    // antes de criar sessao local. Escrita so pelo backend (Cloud Function
    // bypass rules via admin SDK).
    match /test_tokens/{tokenId} {
      allow read: if true;       // login.html valida o token (mas o claim agora é via Cloud Function)
      // updates apenas para flags de auditoria controladas
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used','usedAt','claimed','claimedBy','claimedAt']);
      allow create, delete: if false;  // so backend cria/deleta
    }

    // ============================================
    // DataStore Collection (legado - fase de migracao)
    // ============================================
    match /datastore/{document} {
      // Franchises list e publica (necessario para listagem de lojas no cardapio)
      // iFood docs sao escritos pela extensao Chrome (sem auth - limitacao tecnica)
      // tv_* docs (media library, playlist, config) sao lidos por TVs Android,
      // celulares e browsers kiosk que nao tem sessao auth
      // tv_remote_* docs (comandos da TV Remote) tambem sao publicos p/ controlar TVs
      //
      // SEGURANCA (tightening pos-inauguracao):
      // orders_* / caixa_* / pdv_tabs_* / finances_*: requerem auth + franquia correta.
      // Antes eram publicos (inauguracao); agora isolados por tenant para prevenir
      // vazamento de dados entre franquias (PII de clientes, dados financeiros).
      // 'users' doc: restrito a super_admin (contem nomes, emails, roles de staff).
      //
      // Nota: writes de orders_*/caixa_* continuam publicos para suportar sync offline
      // entre PCs do PDV que possam perder token Firebase temporariamente.
      allow read: if
                    // Documentos publicos (clientes sem auth)
                    document == 'franchises'
                    || document == 'catalog_config'
                    || document.matches('catalog_v2_.*')
                    || document.matches('ifood_.*')
                    || document.matches('tv_.*')
                    || document.matches('tvremote_.*')
                    || document.matches('radio_.*')
                    // Hall da Fama: fotos dos ganhadores 300g. desafio.html?tv=1
                    // (TV indoor publica sem login) precisa ler pra rotacionar
                    // no slide hallFamaLive. Painel/hall-fama.html escreve com
                    // auth de franqueado. Risco zero — fotos vao pro IG publico
                    // de qualquer jeito.
                    || document.matches('hall_da_fama_.*')
                    // Sync operacional entre PCs/celulares: reads publicos (espelham
                    // os writes que ja eram publicos). Tokens Firebase Auth expiram
                    // em 1h e nem sempre auto-refresh — exigir auth quebrava sync
                    // entre dispositivos. Seguranca via obscurity: docs sao keyed
                    // por franchiseId (8+ chars), inviavel scan/guessing externo.
                    || document.matches('orders_.*')
                    || document.matches('caixa_.*')
                    || document.matches('pdv_tabs_.*')
                    || document.matches('finances_.*')
                    // super_admin le tudo
                    || isSuperAdmin()
                    // Outros documentos nao sensiveis (catalog, config, etc.):
                    // qualquer usuario autenticado; 'users' e 'copilot_tunnel' ficam
                    // restritos a super_admin acima (copilot_tunnel contem secret)
                    || (isAuthenticated()
                        && document != 'users'
                        && document != 'copilot_tunnel'
                    );
      // Franchises: somente super_admin pode escrever
      // iFood: extensao escreve sem auth (aceito temporariamente)
      // tv_remote_*: comandos da remote podem ser escritos sem auth (app controla)
      // orders_/caixa_/pdv_tabs_/finances_: writes mantidos sem auth para suportar
      // sync entre PCs do PDV sem token Firebase (escrita so aceita em campo proprio).
      // Outros: usuarios autenticados (franqueados) escrevem seus proprios dados
      // tv_media_* e tv_playlist_* requerem auth (Firebase real ou anon).
      // O painel garante auth state antes de escrever (DataStore._setupAuthWatcher).
      allow write: if document.matches('ifood_.*') ||
                      document.matches('tvremote_.*') ||
                      document.matches('orders_.*') ||
                      document.matches('caixa_.*') ||
                      document.matches('pdv_tabs_.*') ||
                      document.matches('finances_.*') ||
                      (isSuperAdmin() && document == 'franchises') ||
                      (isAuthenticated() && document != 'franchises' && document != 'users');
    }

    // ============================================
    // Users (perfis de usuario)
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isSuperAdmin()
      );
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && resource.data.role != 'super_admin';
    }

    // ============================================
    // Franchises (dados de franquias)
    // ============================================
    match /franchises/{franchiseId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();

      match /orders/{orderId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow create: if isAdminOrFranchiseOwner(franchiseId);
        allow update: if isAdminOrFranchiseOwner(franchiseId);
        allow delete: if isSuperAdmin();
      }

      match /finances/{financeId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow write: if isAdminOrFranchiseOwner(franchiseId);
      }

      match /inventory/{itemId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow write: if isAdminOrFranchiseOwner(franchiseId);
      }

      match /staff/{staffId} {
        allow read: if isAdminOrFranchiseOwner(franchiseId);
        allow write: if isAdminOrFranchiseOwner(franchiseId);
      }
    }

    // ============================================
    // Products (cardapio centralizado - publico)
    // ============================================
    match /products/{productId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ============================================
    // Payments (pagamentos de franquia)
    // ============================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // Settings / Config (configuracoes do sistema)
    // ============================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Config publica (necessario para o jogo Desafio ler premios/config)
    match /config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ============================================
    // Audit Log (somente admin le, imutavel)
    // ============================================
    // Hardening: client AINDA pode gravar (js/core/audit.js depende disso),
    // mas com constraints fortes — userId/userRole travados ao auth real,
    // userName e userEmail strings, timestamp/serverTime preenchidos.
    // Atacante autenticado nao consegue mais forjar 'auth.role_set'
    // com role='super_admin' em nome de outro user.
    // TODO: pos-CF migration, mover writes para Cloud Function logAudit.
    match /audit_log/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated()
                       && request.resource.data.userId == request.auth.uid
                       && (request.resource.data.userRole == null
                           || request.resource.data.userRole == request.auth.token.role)
                       && request.resource.data.event is string
                       && request.resource.data.event.size() <= 80
                       && request.resource.data.diff({}).affectedKeys()
                          .hasOnly(['id','event','timestamp','userId','userName',
                                    'userEmail','userRole','franchiseId','details',
                                    'ip','userAgent']);
      allow update, delete: if false; // Imutavel
    }

    // ============================================
    // Delivery Tracking (posicao GPS em tempo real)
    // ============================================
    match /delivery_tracking/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isSuperAdmin(); // Apenas admin pode deletar rastreamento
    }

    // ============================================
    // DESAFIO 10 MILKYPOT — Collections do jogo
    // ============================================

    // Vouchers gerados pelo PDV / fiscal / delivery
    // Hardening: update SO marca como usado (one-way), nao permite revogar.
    // Ideal pos-launch: mover redemption pra Cloud Function com lock transacional.
    match /desafio_vouchers/{voucherId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Update permite todo o fluxo legitimo (TV claim, jogo, premio, bonus).
      // Restrito a whitelist pra evitar adulteracao de campos sensiveis.
      // BUG (2026-05-19): rule antiga so deixava used:false->true e bloqueava
      // o TV claim (status ready->in_progress + tvAcceptedAt) — TV ficava
      // pegando o mesmo voucher antigo em loop porque o write falhava silente.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['used','usedAt','usedBy','usedAtFranchise','redeemedOrderId',
                                    'status','tvAcceptedAt','attemptsUsed','lastUsedAt',
                                    'attempts','instagramBonusUsed',
                                    'lastPrizeName','lastPrizeTier','lastPrizeRule','lastPrizeAt']);
      allow delete: if isSuperAdmin();
    }

    // Resultados das partidas
    // Hardening: score limitado a 0-10000 (anti-rank injection).
    // Update apenas videoUrl/videoUploadedAt (nao reescrever score).
    match /desafio_10000/{gameId} {
      allow read: if true;
      allow create: if request.resource.data.score is int
                       && request.resource.data.score >= 0
                       && request.resource.data.score <= 10000;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['videoUrl','videoUploadedAt','reactionEmoji']);
      allow delete: if isSuperAdmin();
    }

    // Streaks dos jogadores (por telefone)
    // Hardening: contadores monotonicos (so podem aumentar).
    // Sem isso, atacante zera streak/freePlayCount via DevTools.
    match /desafio_streaks/{playerId} {
      allow read: if true;
      allow create: if request.resource.data.streak is int
                       && request.resource.data.streak >= 0;
      allow update: if request.resource.data.streak is int
                       && request.resource.data.streak >= (resource.data.streak == null ? 0 : resource.data.streak)
                       && request.resource.data.streak <= 10000;
    }

    // Cartelas de carimbo (stamp cards)
    // Hardening: contagem monotonica (so cresce).
    match /desafio_stamps/{playerId} {
      allow read: if true;
      allow create: if request.resource.data.stamps is int
                       && request.resource.data.stamps >= 0;
      allow update: if request.resource.data.stamps is int
                       && request.resource.data.stamps >= (resource.data.stamps == null ? 0 : resource.data.stamps)
                       && request.resource.data.stamps <= 10000;
    }

    // Opt-in de notificacoes WhatsApp
    match /desafio_notifications/{playerId} {
      allow read: if isSuperAdmin();
      allow write: if true;
    }

    // Tentativas gratis por telefone+dia (modo "Acesso Livre")
    // Doc id: {phone}_{YYYY-MM-DD}, contador incrementado a cada tentativa
    // Hardening: count MONOTONICO. Atacante nao consegue zerar pra jogar 24h/dia.
    match /desafio_free_plays/{playId} {
      allow read: if true;
      allow create: if request.resource.data.count is int
                       && request.resource.data.count >= 0
                       && request.resource.data.count <= 50;
      allow update: if request.resource.data.count is int
                       && request.resource.data.count >= resource.data.count
                       && request.resource.data.count <= 50;
    }

    // ============================================
    // RASPINHA DA SORTE - Cada pedido gera 1 raspinha
    // ============================================
    // Hardening: status evolui SO pra frente: pending/available -> scratched -> redeemed.
    // Atacante nao consegue "des-resgatar" pra usar 2x nem reescrever prize.
    match /scratches/{scratchCode} {
      allow read: if true;
      allow create: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status','scratchedAt','redeemedAt','redeemedBy','redeemedAtFranchise','redeemedOrderId'])
                       && (
                            ((resource.data.status == 'pending' || resource.data.status == 'available' || resource.data.status == null)
                              && (request.resource.data.status == 'scratched' || request.resource.data.status == 'redeemed'))
                            || (resource.data.status == 'scratched'
                              && request.resource.data.status == 'redeemed')
                          );
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // TV-PROMO EVENTS — Telemetria da TV indoor + QR scans
    // ============================================
    // desafio.html?tv=1 (TV indoor da loja) e go.html (redirect de QR)
    // gravam aqui pra alimentar painel/tv-promo-metrics.html.
    // Sem essa rule a TV silenciava o erro no .catch e a tela ficava
    // "Carregando dados ao vivo..." pra sempre.
    //
    // Seguranca: append-only, type/slideId/dayKey validados pra evitar
    // flood de lixo. Read so admin/franqueado.
    match /tv_promo_events/{eventId} {
      allow create: if request.resource.data.type in ['view', 'scan']
                       && request.resource.data.dayKey is string
                       && request.resource.data.dayKey.size() == 10
                       && request.resource.data.slideId is string
                       && request.resource.data.slideId.size() > 0
                       && request.resource.data.slideId.size() < 50;
      allow read: if isSuperAdmin() || isFranchisee();
      allow update, delete: if false;
    }

    // ============================================
    // MILKYCLUBE — Programa de fidelidade v1
    // Coins/Tiers/Transactions/Referrals/FCM
    // ============================================

    // Config global do MilkyClube (tiers, bonus, feature flags)
    // Leitura publica para o PWA do clube montar a UI
    match /club_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Membros do clube (1 doc por UID Firebase Auth)
    // Cliente pode ler seu proprio doc e atualizar dados cadastrais
    // mas NUNCA coins/tier/totals (somente Cloud Functions)
    match /club_members/{memberId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == memberId || isSuperAdmin() || isFranchisee()
      );
      allow create: if isAuthenticated() && request.auth.uid == memberId;
      allow update: if isAuthenticated()
        && request.auth.uid == memberId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'coins', 'totalEarned', 'totalRedeemed',
          'tier', 'tierProgress', 'ordersCount', 'totalSpent',
          'birthdayClaimedYear', 'firstOrderBonusClaimed',
          'referralCount', 'referralCode', 'referredBy'
        ]);
      allow delete: if isSuperAdmin();
    }

    // Transacoes de MilkyCoins - imutaveis, so Cloud Function escreve
    match /milkycoins_transactions/{txId} {
      allow read: if isAuthenticated() && (
        resource.data.memberId == request.auth.uid || isSuperAdmin() || isFranchisee()
      );
      allow write: if false; // Somente Cloud Functions via admin SDK
    }

    // Codigos de indicacao (referral) - leitura publica para validar codigo
    match /club_referrals/{code} {
      allow read: if true;
      allow write: if false; // Somente Cloud Functions
    }

    // Tokens FCM (push) - somente Cloud Functions gravam
    match /fcm_tokens/{tokenHash} {
      allow read: if isSuperAdmin();
      allow write: if false; // Somente Cloud Functions
    }

    // Fila de envios WhatsApp - franqueado le sua fila, CF escreve
    match /whatsapp_queue/{queueId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow update: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow create, delete: if false; // Somente Cloud Functions criam
    }

    // Agenda de postagens de marketing (plano viral MilkyClube IG/TikTok)
    match /marketing_agenda/{postId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // MILKYCLUBE — Programa de fidelidade v1
    // Coins/Tiers/Transactions/Referrals/FCM
    // ============================================

    // Config global do MilkyClube (tiers, bonus, feature flags)
    // Leitura publica para o PWA do clube montar a UI
    match /club_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Membros do clube (1 doc por UID Firebase Auth)
    // Cliente pode ler seu proprio doc e atualizar dados cadastrais
    // mas NUNCA coins/tier/totals (somente Cloud Functions)
    match /club_members/{memberId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == memberId || isSuperAdmin() || isFranchisee()
      );
      allow create: if isAuthenticated() && request.auth.uid == memberId;
      allow update: if isAuthenticated()
        && request.auth.uid == memberId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'coins', 'totalEarned', 'totalRedeemed',
          'tier', 'tierProgress', 'ordersCount', 'totalSpent',
          'birthdayClaimedYear', 'firstOrderBonusClaimed',
          'referralCount', 'referralCode', 'referredBy'
        ]);
      allow delete: if isSuperAdmin();
    }

    // Eventos do MilkyPass - gravados por Cloud Functions e lidos no admin
    match /club_pass_events/{eventId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow write: if false;
    }

    // Transacoes de MilkyCoins - imutaveis, so Cloud Function escreve
    match /milkycoins_transactions/{txId} {
      allow read: if isAuthenticated() && (
        resource.data.memberId == request.auth.uid || isSuperAdmin() || isFranchisee()
      );
      allow write: if false; // Somente Cloud Functions via admin SDK
    }

    // Codigos de indicacao (referral) - leitura publica para validar codigo
    match /club_referrals/{code} {
      allow read: if true;
      allow write: if false; // Somente Cloud Functions
    }

    // Tokens FCM (push) - somente Cloud Functions gravam
    match /fcm_tokens/{tokenHash} {
      allow read: if isSuperAdmin();
      allow write: if false; // Somente Cloud Functions
    }

    // Fila de envios WhatsApp - franqueado le sua fila, CF escreve
    match /whatsapp_queue/{queueId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow update: if isAuthenticated() && (isSuperAdmin() || isFranchisee());
      allow create, delete: if false; // Somente Cloud Functions criam
    }

    // Agenda de postagens de marketing (plano viral MilkyClube IG/TikTok)
    match /marketing_agenda/{postId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // Action Claims — Earn-before-claim engine.
    // Cliente reivindica recompensa via ação (review Google, story IG, etc).
    // Apenas Cloud Functions criam/atualizam (via admin SDK). Cliente identificado
    // pode ler seus próprios claims pra ver status. Admin lê tudo.
    // ============================================
    match /action_claims/{claimId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || isFranchisee() ||
        (resource.data.memberId == request.auth.uid)
      );
      allow create, update, delete: if false; // só Cloud Functions
    }

    // ============================================
    // Mail queue — Cloud Functions escrevem aqui pra fallback de SMTP.
    // Tambem podem ser lidas pela Trigger Email Extension (se instalada).
    // Apenas authenticated users criam (PDV ao fechar caixa); ler so super_admin.
    // ============================================
    match /mail/{mailId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // Franchise Leads — Lista VIP de pré-inscrição
    // ============================================
    // Visitantes ANÔNIMOS na landing fazem signInAnonymously() antes de
    // gravar o lead. Validação: campos mínimos presentes, tamanhos
    // limitados, origem fixa pra evitar abuse via console.
    // Read/update/delete: super_admin OU franchisee (Jocimar acessa via
    // /painel/franquia-leads.html — atualiza historico/status do lead).
    match /franchise_leads/{leadId} {
      allow read: if isSuperAdmin() || isFranchisee();
      allow create: if isAuthenticated()
                     && request.resource.data.keys().hasAll(['nome','whatsapp','email','cidade','uf','capital','formato','perfil','origem','criadoEm'])
                     && request.resource.data.nome is string
                     && request.resource.data.nome.size() > 1
                     && request.resource.data.nome.size() < 200
                     && request.resource.data.email is string
                     && request.resource.data.email.size() > 5
                     && request.resource.data.email.size() < 200
                     && request.resource.data.whatsapp is string
                     && request.resource.data.whatsapp.size() >= 10
                     && request.resource.data.whatsapp.size() <= 15
                     && request.resource.data.origem == 'landing#franquia';
      allow update: if isSuperAdmin() || isFranchisee();
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // WhatsApp Conversations — chat histórico Lulu IA
    // ============================================
    // Webhook /api/whatsapp-webhook escreve via REST (sem auth Firebase) —
    // por isso allow read/write é PÚBLICO mas validamos no servidor que
    // a chamada é assinada com HMAC do MP_WEBHOOK_SECRET.
    // Painel admin (super_admin/franchisee) lê + atualiza pra pausar IA.
    match /whatsapp_conversations/{phone} {
      // Read: super_admin, franchisee (pra ver no painel) E público
      // (pra webhook serverless ler histórico antes de chamar Lulu)
      allow read: if true;
      // Create/update: público (webhook serverless escreve sem auth Firebase)
      // Validação: campos obrigatórios + tipos corretos + tamanhos limitados
      allow create, update: if request.resource.data.phone is string
                             && request.resource.data.phone.size() > 5
                             && request.resource.data.phone.size() < 20
                             && request.resource.data.messages is list
                             && request.resource.data.messages.size() <= 100;
      allow delete: if isSuperAdmin();
    }

    // Audit de relatorios de caixa enviados — Cloud Function grava
    match /caixa_reports_sent/{docId} {
      allow read: if isSuperAdmin() || isFranchisee();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // Bloqueia tudo que nao foi definido explicitamente
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
